# Track ONLY the runnable code — ignore everything else.
# hopper*.lua + servers.txt are regenerated on the phone (setup.sh / autoupdate.sh).
# link.txt, token.txt, cmd/, inv/, logs, archive/, docs stay local to each machine.
*
!.gitignore
!.gitattributes
!master_bot.py
!server.py
!agent.py
!autoupdate.sh
!vps_update.sh
!vps_update.ps1
!monitor.ps1
!setuprdp.ps1
!setup.sh
!monitor_adoptme.lua
